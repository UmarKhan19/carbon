# Carbon production reverse proxy. Auto-HTTPS via Let's Encrypt.
# Hostnames + ACME email come from the compose environment (envsubst-style
# {$VAR} placeholders, resolved by Caddy at load from container env).

{
	email {$ACME_EMAIL}
}

# ERP
{$ERP_HOST} {
	reverse_proxy erp:3000
}

# MES
{$MES_HOST} {
	reverse_proxy mes:3000
}

# Supabase API gateway (kong) — browser-facing: auth, REST, storage, realtime ws, functions
{$SUPABASE_HOST} {
	reverse_proxy kong:8000
}
