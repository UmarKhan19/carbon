{
  "name": "@carbon/onboarding",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts",
    "./ui": "./src/ui/index.ts"
  },
  "dependencies": {
    "@carbon/database": "workspace:*",
    "@carbon/form": "workspace:*",
    "@carbon/react": "workspace:*",
    "@carbon/utils": "workspace:*",
    "@internationalized/date": "catalog:",
    "@supabase/supabase-js": "catalog:",
    "react": "catalog:",
    "react-icons": "catalog:",
    "zod": "catalog:",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@carbon/config": "workspace:*",
    "@types/react": "catalog:",
    "rimraf": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "scripts": {
    "clean": "rimraf .turbo node_modules dist",
    "dev": "tsup --watch",
    "lint": "biome lint --write ",
    "test": "vitest run",
    "typecheck": "tsgo --noEmit"
  }
}
