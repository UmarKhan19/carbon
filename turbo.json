{
  "$schema": "https://turborepo.org/schema.json",
  "tasks": {
    "//#lingui:compile": {
      "inputs": [
        "lingui.config.js",
        "apps/erp/app/**",
        "apps/mes/app/**",
        "packages/react/src/**",
        "packages/locale/locales/**/*.po"
      ],
      "outputs": ["packages/locale/locales/**/*.mjs"]
    },
    "build": {
      "dependsOn": ["^build", "//#lingui:compile"],
      "outputs": [
        "dist/**",
        "build/**",
        "api/**",
        ".vercel/**",
        "public/build/**",
        ".next/**",
        "!.next/cache/**"
      ]
    },
    "clean": {
      "cache": false
    },
    "db:init": {
      "outputs": []
    },
    "db:migrate": {
      "cache": false,
      "outputs": []
    },
    "db:seed": {
      "cache": false,
      "outputs": []
    },
    "db:types": {
      "cache": true,
      "outputs": []
    },
    "deploy": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "dependsOn": ["^build"],
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "cache": false,
      "dependsOn": []
    },
    "typecheck": {
      "cache": false,
      "dependsOn": []
    },
    "typegen": {
      "cache": false,
      "outputs": []
    }
  }
}
